<UserControl x:Class="FastSort.Client.Windows.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="账号资料"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FastSortText}" />
                <TextBlock Text="昵称" Foreground="{StaticResource FastSortMuted}" FontSize="12" Margin="0,14,0,4" />
                <TextBox Text="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                <Button Content="保存昵称"
                        Command="{Binding PrimaryActionCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,10,0,16" />

                <TextBlock Text="新密码" Foreground="{StaticResource FastSortMuted}" FontSize="12" Margin="0,0,0,4" />
                <TextBox Text="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                <Button Content="保存密码"
                        Command="{Binding SecondaryActionCommand}"
                        Margin="0,10,0,16" />

                <TextBlock Text="手机号" Foreground="{StaticResource FastSortMuted}" FontSize="12" Margin="0,0,0,4" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                <TextBlock Text="验证码" Foreground="{StaticResource FastSortMuted}" FontSize="12" Margin="0,10,0,4" />
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Height="34" />
                <Button Content="发送/更新手机号"
                        Command="{Binding TertiaryActionCommand}"
                        Margin="0,10,0,16" />

                <Button Content="注销账号"
                        Command="{Binding DangerActionCommand}"
                        Foreground="{StaticResource FastSortDanger}" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource FastSortMuted}"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <DataGrid ItemsSource="{Binding DetailRows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="150" />
                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="180" />
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
