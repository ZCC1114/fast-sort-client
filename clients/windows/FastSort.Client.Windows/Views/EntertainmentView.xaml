<UserControl x:Class="FastSort.Client.Windows.Views.EntertainmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="直播间列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,12,0,12"
                             VerticalContentAlignment="Center" />
                    <Button Content="刷新房间"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,0,12" />
                </StackPanel>
                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <DockPanel>
                                    <TextBlock Text="▶"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource FastSortAccent}"
                                               FontWeight="Bold" />
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FastSortText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Detail}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="当前直播间"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}" />
                            <TextBlock Text="{Binding StatusText}"
                                       DockPanel.Dock="Right"
                                       Foreground="{StaticResource FastSortMuted}"
                                       TextTrimming="CharacterEllipsis"
                                       Width="360" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource FastSortBackground}"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource FastSortText}" />
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="互动输出"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBox Text="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                                 Height="34"
                                 Margin="0,12,0,12"
                                 VerticalContentAlignment="Center" />
                        <UniformGrid Columns="2" Rows="4" Margin="0,0,0,14">
                            <CheckBox Content="弹幕打印" Margin="0,0,8,8" />
                            <CheckBox Content="弹幕播报" Margin="0,0,0,8" />
                            <CheckBox Content="进房打印" Margin="0,0,8,8" />
                            <CheckBox Content="进房播报" Margin="0,0,0,8" />
                            <CheckBox Content="点赞打印" Margin="0,0,8,8" />
                            <CheckBox Content="点赞播报" Margin="0,0,0,8" />
                            <CheckBox Content="送礼打印" IsChecked="True" Margin="0,0,8,0" />
                            <CheckBox Content="送礼播报" IsChecked="True" />
                        </UniformGrid>
                        <WrapPanel>
                            <Button Content="{Binding PrimaryActionText}"
                                    Command="{Binding PrimaryActionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,8" />
                            <Button Content="{Binding SecondaryActionText}"
                                    Command="{Binding SecondaryActionCommand}"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="互动事件"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="全部" Style="{StaticResource TopbarTextButton}" Margin="0,0,8,0" />
                            <Button Content="弹幕" Style="{StaticResource TopbarTextButton}" Margin="0,0,8,0" />
                            <Button Content="礼物" Style="{StaticResource TopbarTextButton}" />
                        </StackPanel>
                    </DockPanel>
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding DetailRows}"
                              SelectedItem="{Binding SelectedRow}"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Time}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   FontSize="12" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}" />
                                            <TextBlock Text="{Binding Detail}"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
