<UserControl x:Class="FastSort.Client.Windows.Views.VipOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="订单列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                </StackPanel>
                <WrapPanel Margin="0,12,0,0">
                    <ListBox SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             SelectionChanged="AutoRefreshSelector_SelectionChanged"
                             Margin="0,0,12,0">
                        <ListBoxItem Content="全部" Tag="all" />
                        <ListBoxItem Content="已支付" Tag="paid" />
                        <ListBoxItem Content="待支付" Tag="pending" />
                        <ListBoxItem Content="已取消" Tag="canceled" />
                        <ListBoxItem Content="支付失败" Tag="failed" />
                    </ListBox>
                </WrapPanel>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.0*" />
                        <ColumnDefinition Width="1.7*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="1" Text="套餐" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="2" Text="时长/方式" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="3" Text="开始-结束时间" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="4" Text="支付金额" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="5" Text="状态" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                    <TextBlock Grid.Column="6" Text="创建时间" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding DetailRows}"
                         SelectedItem="{Binding SelectedRow}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource FastSortBorder}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="1.0*" />
                                        <ColumnDefinition Width="1.7*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Sequence}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding Meta}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding Amount}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="5" Text="{Binding Status}" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="6" Text="{Binding Time}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <DockPanel Grid.Row="3" LastChildFill="False" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PageText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" Margin="12,0,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="上一页" Command="{Binding PreviousPageCommand}" Margin="0,0,8,0" />
                    <Button Content="下一页" Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
