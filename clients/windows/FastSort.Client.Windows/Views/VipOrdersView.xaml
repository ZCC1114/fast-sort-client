<UserControl x:Class="FastSort.Client.Windows.Views.VipOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="订单列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <TextBlock Text="{Binding PageText}"
                               FontSize="12"
                               Foreground="{StaticResource FastSortMuted}"
                               Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ComboBox Width="360"
                              SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Margin="0,0,12,0">
                        <ComboBoxItem Content="全部" Tag="all" />
                        <ComboBoxItem Content="已支付" Tag="paid" />
                        <ComboBoxItem Content="待支付" Tag="pending" />
                        <ComboBoxItem Content="已取消" Tag="canceled" />
                        <ComboBoxItem Content="支付失败" Tag="failed" />
                    </ComboBox>
                    <Button Content="刷新"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </DockPanel>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding DetailRows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="套餐" Binding="{Binding Name}" Width="170" />
                    <DataGridTextColumn Header="时长/方式" Binding="{Binding Detail}" Width="180" />
                    <DataGridTextColumn Header="开始-结束时间" Binding="{Binding Meta}" Width="280" />
                    <DataGridTextColumn Header="支付金额" Binding="{Binding Amount}" Width="120" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120" />
                    <DataGridTextColumn Header="创建时间" Binding="{Binding Time}" Width="180" />
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220" />
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="上一页" Command="{Binding PreviousPageCommand}" Margin="0,0,8,0" />
                    <Button Content="下一页" Command="{Binding NextPageCommand}" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
