<UserControl x:Class="FastSort.Client.Windows.Views.BusinessPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBlock Text="{Binding Subtitle}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Content="刷新"
                            Command="{Binding RefreshCommand}"
                            DockPanel.Dock="Right"
                            MinWidth="76" />
                </DockPanel>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Metrics}"
                              Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    BorderBrush="{StaticResource FastSortBorder}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    MinWidth="140"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                    <StackPanel Width="180"
                                Margin="0,0,10,8"
                                Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding SearchLabel}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Width="180"
                                Margin="0,0,10,8"
                                Visibility="{Binding IsFilterVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding FilterLabel}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Width="180"
                                Margin="0,0,10,8"
                                Visibility="{Binding IsInputOneVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding InputOneLabel}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Width="180"
                                Margin="0,0,10,8"
                                Visibility="{Binding IsInputTwoVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding InputTwoLabel}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Width="180"
                                Margin="0,0,10,8"
                                Visibility="{Binding IsInputThreeVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding InputThreeLabel}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                        <TextBox Text="{Binding InputThree, UpdateSourceTrigger=PropertyChanged}"
                                 Height="32"
                                 Margin="0,4,0,0" />
                    </StackPanel>
                </WrapPanel>

                <StackPanel Visibility="{Binding IsTextAreaVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Grid.Row="3"
                            Margin="0,0,0,10">
                    <TextBlock Text="{Binding TextAreaLabel}"
                               Foreground="{StaticResource FastSortMuted}"
                               FontSize="12" />
                    <TextBox Text="{Binding TextAreaText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             MinHeight="120"
                             Margin="0,4,0,0" />
                </StackPanel>

                <DockPanel Grid.Row="4">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource FastSortMuted}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button Content="{Binding PrimaryActionText}"
                                Command="{Binding PrimaryActionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="92"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsPrimaryVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="{Binding SecondaryActionText}"
                                Command="{Binding SecondaryActionCommand}"
                                MinWidth="92"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsSecondaryVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="{Binding TertiaryActionText}"
                                Command="{Binding TertiaryActionCommand}"
                                MinWidth="92"
                                Margin="8,0,0,0"
                                Visibility="{Binding IsTertiaryVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Content="{Binding DangerActionText}"
                                Command="{Binding DangerActionCommand}"
                                MinWidth="92"
                                Margin="8,0,0,0"
                                Foreground="#FFE74C3C"
                                Visibility="{Binding IsDangerVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="8">
            <DataGrid ItemsSource="{Binding Rows}"
                      SelectedItem="{Binding SelectedRow}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="类型" Binding="{Binding Kind}" Width="110" />
                    <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="190" />
                    <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                    <DataGridTextColumn Header="信息" Binding="{Binding Meta}" Width="160" />
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="130" />
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="170" />
                    <DataGridTextColumn Header="金额" Binding="{Binding Amount}" Width="90" />
                    <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Text="{Binding PageText}"
                       Foreground="{StaticResource FastSortMuted}"
                       VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <TextBlock Text="每页"
                           Foreground="{StaticResource FastSortMuted}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Text="{Binding PageSize, UpdateSourceTrigger=PropertyChanged}"
                         Width="54"
                         Height="30"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center" />
                <Button Content="上一页"
                        Command="{Binding PreviousPageCommand}"
                        MinWidth="76"
                        Margin="0,0,8,0" />
                <Button Content="下一页"
                        Command="{Binding NextPageCommand}"
                        MinWidth="76" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
