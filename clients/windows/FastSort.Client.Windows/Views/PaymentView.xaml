<UserControl x:Class="FastSort.Client.Windows.Views.PaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="会员权益"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FastSortText}" />
                <TextBlock Text="开通后解锁全网黑名单、批量备注、更多直播间和高级打印能力。"
                           Foreground="{StaticResource FastSortMuted}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,16" />
                <Button Content="刷新套餐"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,0,10" />
                <Button Content="支付选中套餐"
                        Command="{Binding PrimaryActionCommand}"
                        Style="{StaticResource PrimaryButton}" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource FastSortMuted}"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <ListBox ItemsSource="{Binding DetailRows}"
                     SelectedItem="{Binding SelectedRow}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource FastSortBackground}"
                                CornerRadius="10"
                                Padding="16"
                                Margin="0,0,0,12">
                            <DockPanel>
                                <TextBlock Text="{Binding Amount}"
                                           DockPanel.Dock="Right"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FastSortAccent}" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Detail}"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding Meta}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
