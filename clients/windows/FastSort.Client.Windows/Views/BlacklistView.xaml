<UserControl x:Class="FastSort.Client.Windows.Views.BlacklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <ComboBox Width="150"
                              SelectedValue="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Margin="0,0,10,0">
                        <ComboBoxItem Content="我的黑名单" Tag="mine" />
                        <ComboBoxItem Content="全网黑名单" Tag="global" />
                    </ComboBox>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="220"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0" />
                    <ComboBox Width="130"
                              SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Margin="0,0,10,0">
                        <ComboBoxItem Content="全部等级" Tag="" />
                        <ComboBoxItem Content="LV1" Tag="1" />
                        <ComboBoxItem Content="LV2" Tag="2" />
                        <ComboBoxItem Content="LV3" Tag="3" />
                        <ComboBoxItem Content="LV4" Tag="4" />
                        <ComboBoxItem Content="LV5" Tag="5" />
                    </ComboBox>
                    <ComboBox Width="140"
                              SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="全部平台" Tag="" />
                        <ComboBoxItem Content="抖音" Tag="0" />
                        <ComboBoxItem Content="淘宝" Tag="1" />
                        <ComboBoxItem Content="小红书" Tag="2" />
                        <ComboBoxItem Content="微信" Tag="3" />
                        <ComboBoxItem Content="快手" Tag="4" />
                    </ComboBox>
                </StackPanel>
                <Button Content="搜索"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}"
                        DockPanel.Dock="Right" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="黑名单列表"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBlock Text="{Binding PageText}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12"
                                   Margin="0,4,0,12" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding PrimaryRows}"
                             SelectedItem="{Binding SelectedRow}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Meta}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource FastSortAccent}"
                                                   FontWeight="SemiBold" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}" />
                                            <TextBlock Text="{Binding Detail}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding Time}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding Metrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource FastSortText}" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource FastSortMuted}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding DetailRows}"
                              SelectedItem="{Binding SelectedRow}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="180" />
                            <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                            <DataGridTextColumn Header="类型" Binding="{Binding Meta}" Width="140" />
                            <DataGridTextColumn Header="金额" Binding="{Binding Amount}" Width="100" />
                            <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="170" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DockPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="加载详情"
                                    Command="{Binding PrimaryActionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="删除明细"
                                    Command="{Binding SecondaryActionCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
