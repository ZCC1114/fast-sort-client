<UserControl x:Class="FastSort.Client.Windows.Views.BlacklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <StackPanel>
                <WrapPanel>
                    <ListBox SelectedValue="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             SelectionChanged="FilterSelector_SelectionChanged"
                             Margin="0,0,10,8">
                        <ListBoxItem Content="我的黑名单" Tag="mine" />
                        <ListBoxItem Content="全网黑名单" Tag="global" />
                    </ListBox>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="260"
                             Height="34"
                             Margin="0,0,10,8" />
                    <Button Content="搜索"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Width="110"
                            Margin="0,0,0,8" />
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <ListBox SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             SelectionChanged="FilterSelector_SelectionChanged"
                             Margin="0,0,10,0">
                        <ListBoxItem Content="全部等级" Tag="" />
                        <ListBoxItem Content="LV1" Tag="1" />
                        <ListBoxItem Content="LV2" Tag="2" />
                        <ListBoxItem Content="LV3" Tag="3" />
                        <ListBoxItem Content="LV4" Tag="4" />
                        <ListBoxItem Content="LV5" Tag="5" />
                    </ListBox>
                    <ListBox SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             SelectionChanged="FilterSelector_SelectionChanged">
                        <ListBoxItem Content="全部平台" Tag="" />
                        <ListBoxItem Content="抖音" Tag="0" />
                        <ListBoxItem Content="淘宝" Tag="1" />
                        <ListBoxItem Content="小红书" Tag="2" />
                        <ListBoxItem Content="微信" Tag="3" />
                        <ListBoxItem Content="快手" Tag="4" />
                    </ListBox>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="黑名单列表"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <Grid Margin="0,12,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="54" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="序号" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                            <TextBlock Grid.Column="1" Text="黑名单信息" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                            <TextBlock Grid.Column="2" Text="等级" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding PrimaryRows}"
                             SelectedItem="{Binding SelectedRow}"
                             ItemContainerStyle="{StaticResource PlainListBoxItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="54" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Sequence}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Detail}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,5,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Time}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,5,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Meta}"
                                                   Foreground="{StaticResource FastSortAccent}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="详情"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,14,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource FastSortBackground}"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}" />
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource FastSortText}"
                                                       Margin="0,5,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding DetailRows}"
                             SelectedItem="{Binding SelectedRow}"
                             ItemContainerStyle="{StaticResource PlainListBoxItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Amount}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{StaticResource FastSortAccent}"
                                                       FontWeight="SemiBold" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Detail}"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Meta}"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,6,0,0" />
                                        <TextBlock Text="{Binding Time}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <DockPanel Grid.Row="3" Style="{StaticResource PaginationBar}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageText}"
                                       Style="{StaticResource PaginationInfoText}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource PaginationInfoText}"
                                       TextWrapping="Wrap"
                                       Margin="12,0,0,0" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="上一页"
                                    Command="{Binding PreviousPageCommand}"
                                    Style="{StaticResource PaginationButton}" />
                            <Button Content="下一页"
                                    Command="{Binding NextPageCommand}"
                                    Style="{StaticResource PaginationButton}" />
                            <Button Content="加载详情"
                                    Command="{Binding PrimaryActionCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="删除明细"
                                    Command="{Binding SecondaryActionCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
