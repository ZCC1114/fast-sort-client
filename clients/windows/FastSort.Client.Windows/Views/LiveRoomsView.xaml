<UserControl x:Class="FastSort.Client.Windows.Views.LiveRoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Loaded="LiveRoomsView_Loaded"
             MinHeight="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource FastSortSurface}"
                BorderBrush="{StaticResource FastSortBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox ItemsSource="{Binding Platforms}"
                          SelectedItem="{Binding SelectedPlatform}"
                          DisplayMemberPath="Name"
                          Height="34"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                         Height="34"
                         Margin="10,0"
                         VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource FastSortMuted}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="3"
                        Content="Open Auth"
                        Command="{Binding OpenSelectedPlatformCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="92"
                        Margin="10,0,8,0" />
                <Button Grid.Column="4"
                        Content="Collect"
                        Click="CollectButton_Click"
                        MinWidth="72"
                        Margin="0,0,8,0" />
                <Button Grid.Column="5"
                        Content="Save Room"
                        Command="{Binding SaveAuthorizedRoomCommand}"
                        MinWidth="92" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1.1*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="0.9*" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0"
                    Grid.RowSpan="3"
                    Background="{StaticResource FastSortSurface}"
                    BorderBrush="{StaticResource FastSortBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <wv2:WebView2 x:Name="AuthWebView"
                              NavigationStarting="AuthWebView_NavigationStarting"
                              NavigationCompleted="AuthWebView_NavigationCompleted" />
            </Border>

            <Border Grid.Column="2"
                    Grid.Row="0"
                    Background="{StaticResource FastSortSurface}"
                    BorderBrush="{StaticResource FastSortBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Backend Rooms"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <Button Content="Refresh"
                                Command="{Binding LoadRoomsCommand}"
                                DockPanel.Dock="Right"
                                MinWidth="68" />
                    </DockPanel>
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Rooms}"
                              SelectedItem="{Binding SelectedRoom}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="130" />
                                <GridViewColumn Header="Platform" DisplayMemberBinding="{Binding Platform}" Width="120" />
                                <GridViewColumn Header="liveSession" DisplayMemberBinding="{Binding LiveSessionStatus}" Width="130" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Grid.Row="2"
                    Background="{StaticResource FastSortSurface}"
                    BorderBrush="{StaticResource FastSortBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Auth And Native Events"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <Button Content="Stop"
                                Command="{Binding StopNativeConnectionCommand}"
                                DockPanel.Dock="Right"
                                MinWidth="72" />
                        <Button Content="Connect"
                                Command="{Binding ConnectSelectedRoomCommand}"
                                DockPanel.Dock="Right"
                                MinWidth="86"
                                Margin="0,0,8,0" />
                    </DockPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="{Binding CurrentUrl}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding HitStatusText}"
                                   Foreground="{StaticResource FastSortAccent}"
                                   FontWeight="SemiBold"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="{Binding CollectionResultText}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                        <TextBox Text="{Binding MaskedCookieHeader, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="58"
                                 MaxHeight="86"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,8,0,0" />
                    </StackPanel>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding Events}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="64" />
                                <GridViewColumn Header="Platform" DisplayMemberBinding="{Binding Platform}" Width="90" />
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="86" />
                                <GridViewColumn Header="Content" DisplayMemberBinding="{Binding Content}" Width="260" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
