<UserControl x:Class="FastSort.Client.Windows.Views.LiveRoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Loaded="LiveRoomsView_Loaded"
             MinHeight="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="直播间列表"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}" />
                            <TextBlock Text="{Binding Rooms.Count, StringFormat=共 {0} 个}"
                                       FontSize="12"
                                       Foreground="{StaticResource FastSortMuted}"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                        <Button Content="+"
                                Command="{Binding OpenSelectedPlatformCommand}"
                                Style="{StaticResource PrimaryButton}"
                                DockPanel.Dock="Right"
                                Width="34"
                                Height="34"
                                Padding="0" />
                    </DockPanel>

                    <ComboBox ItemsSource="{Binding Platforms}"
                              SelectedItem="{Binding SelectedPlatform}"
                              DisplayMemberPath="Name"
                              Height="34"
                              Margin="0,0,0,12" />
                    <TextBox Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,12" />
                    <Button Content="刷新房间"
                            Command="{Binding LoadRoomsCommand}"
                            Margin="0,0,0,12" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Rooms}"
                         SelectedItem="{Binding SelectedRoom}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="{StaticResource FastSortBorder}"
                                    BorderThickness="1">
                                <DockPanel>
                                    <TextBlock Text="▶"
                                               DockPanel.Dock="Right"
                                               Foreground="{StaticResource FastSortAccent}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FastSortText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Platform}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource FastSortAccent}"
                                                   Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding RoomMeta}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding LiveSessionStatus}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="当前直播间"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBlock Text="{Binding StatusText}"
                                   DockPanel.Dock="Right"
                                   Width="420"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12" />
                    </DockPanel>
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="平台" FontSize="12" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Text="{Binding SelectedRoom.Platform}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="直播间" FontSize="12" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Text="{Binding SelectedRoom.Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="房间信息" FontSize="12" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Text="{Binding SelectedRoom.RoomMeta}" FontSize="13" Foreground="{StaticResource FastSortText}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="12">
                            <StackPanel>
                                <TextBlock Text="登录态" FontSize="12" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Text="{Binding SelectedRoom.LiveSessionStatus}" FontSize="13" Foreground="{StaticResource FastSortText}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="开始直播/连接弹幕"
                                Command="{Binding ConnectSelectedRoomCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,8" />
                        <Button Content="断开弹幕"
                                Command="{Binding StopNativeConnectionCommand}"
                                Margin="0,0,8,8" />
                        <Button Content="重连弹幕"
                                Command="{Binding ConnectSelectedRoomCommand}"
                                Margin="0,0,8,8" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FastSortAccentSoft}" CornerRadius="12" Padding="10,6" Margin="0,0,10,0">
                                <TextBlock Text="弹幕面板" Foreground="{StaticResource FastSortAccent}" FontWeight="SemiBold" />
                            </Border>
                            <CheckBox Content="仅粉丝打印" Margin="0,0,12,0" />
                            <CheckBox Content="去重模式" Margin="0,0,12,0" />
                            <CheckBox Content="竞拍模式" Margin="0,0,12,0" />
                            <CheckBox Content="九宫格模式" />
                        </StackPanel>
                    </DockPanel>
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Events}"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Time}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   FontSize="12" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource FastSortText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Platform, StringFormat={}{0}}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="打印机"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <Border DockPanel.Dock="Right" Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="9,5">
                            <TextBlock Text="未连接" Foreground="{StaticResource FastSortMuted}" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </DockPanel>
                    <Border Background="{StaticResource FastSortBackground}" CornerRadius="10" Padding="12" Margin="0,14,0,12">
                        <StackPanel>
                            <TextBlock Text="未连接本地打印机" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" />
                            <TextBlock Text="标签尺寸按房间模板配置读取" FontSize="12" Foreground="{StaticResource FastSortMuted}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <WrapPanel>
                        <Button Content="搜索设备" Margin="0,0,8,0" />
                        <Button Content="断开连接" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="添加直播间授权"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBlock Text="选择平台和可选备注，打开工作台登录页后采集 Cookie 并保存到 liveSession。"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12"
                                   Margin="0,6,0,12" />
                        <WrapPanel>
                            <Button Content="打开登录页"
                                    Command="{Binding OpenSelectedPlatformCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,8" />
                            <Button Content="采集 Cookie"
                                    Click="CollectButton_Click"
                                    Margin="0,0,8,8" />
                            <Button Content="保存 liveSession"
                                    Command="{Binding SaveAuthorizedRoomCommand}"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding HitStatusText}"
                                   Foreground="{StaticResource FastSortSuccess}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="{Binding CollectionResultText}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Text="{Binding CurrentUrl}"
                               Foreground="{StaticResource FastSortMuted}"
                               FontSize="11"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               Margin="0,12,0,8" />
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource FastSortBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            ClipToBounds="True">
                        <wv2:WebView2 x:Name="AuthWebView"
                                      NavigationStarting="AuthWebView_NavigationStarting"
                                      NavigationCompleted="AuthWebView_NavigationCompleted" />
                    </Border>
                    <TextBox Grid.Row="3"
                             Text="{Binding MaskedCookieHeader, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MaxHeight="90"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
