<UserControl x:Class="FastSort.Client.Windows.Views.LiveRoomsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="LiveRoomsView_Loaded"
             MinHeight="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <DockPanel Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="直播间列表"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FastSortText}" />
                                <TextBlock Text="{Binding VisibleRooms.Count, StringFormat=（{0}）}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FastSortMuted}"
                                           Margin="6,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                        <Button Command="{Binding OpenAuthorizationPageCommand}"
                                Style="{StaticResource TopbarTextButton}"
                                DockPanel.Dock="Right"
                                Padding="10,6"
                                ToolTip="添加直播间">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="添加直播间"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <ListBox ItemsSource="{Binding PlatformFilters}"
                             SelectedItem="{Binding SelectedPlatformFilter}"
                             Style="{StaticResource SegmentedSelector}"
                             Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,0,0,12"
                             ToolTip="按昵称、平台、编号搜索" />
                </StackPanel>

                <ListBox ItemsSource="{Binding VisibleRooms}"
                         SelectedItem="{Binding SelectedRoom}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="RoomCard"
                                    Background="{StaticResource FastSortBackground}"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,10"
                                    BorderBrush="{StaticResource FastSortBorder}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="34" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="42"
                                            Height="42"
                                            CornerRadius="10"
                                            Background="{Binding PlatformBadgeBackground}"
                                            VerticalAlignment="Center"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding AvatarUrl}"
                                                   Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding AvatarText}"
                                                       Foreground="{Binding PlatformBadgeForeground}"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,8,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FastSortText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <WrapPanel Margin="0,5,0,0">
                                            <Border Background="{Binding PlatformBadgeBackground}"
                                                    CornerRadius="9"
                                                    Padding="7,2"
                                                    Margin="0,0,6,0">
                                                <TextBlock Text="{Binding Platform}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding PlatformBadgeForeground}" />
                                            </Border>
                                            <TextBlock Text="{Binding Handle}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Width="30"
                                            Height="30"
                                            CornerRadius="15"
                                            Background="{StaticResource FastSortAccent}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="RoomCard" Property="Background" Value="{StaticResource FastSortAccentSoft}" />
                                    <Setter TargetName="RoomCard" Property="BorderBrush" Value="#FFD1E4FF" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <Border DockPanel.Dock="Right"
                                    Background="{StaticResource FastSortBackground}"
                                    CornerRadius="12"
                                    Padding="10,6">
                                <TextBlock Text="{Binding ConnectionStatusText}"
                                           Foreground="{StaticResource FastSortMuted}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE714;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource FastSortText}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="当前直播间"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FastSortText}" />
                            </StackPanel>
                        </DockPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />
                                <RowDefinition Height="32" />
                                <RowDefinition Height="40" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="平台" Foreground="{StaticResource FastSortMuted}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedRoomPlatformText}" Foreground="{StaticResource FastSortText}" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="360" HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Text="直播间" Foreground="{StaticResource FastSortMuted}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedRoomNameText}" Foreground="{StaticResource FastSortText}" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="360" HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Text="房间号" Foreground="{StaticResource FastSortMuted}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedRoomNumberText}" Foreground="{StaticResource FastSortText}" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="360" HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Text="连接状态" Foreground="{StaticResource FastSortMuted}" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedRoomSessionText}" Foreground="{StaticResource FastSortText}" FontSize="14" FontWeight="SemiBold" TextAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="360" HorizontalAlignment="Right" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="4" Text="打印模式" Foreground="{StaticResource FastSortMuted}" FontSize="13" VerticalAlignment="Center" />
                            <ListBox Grid.Row="4"
                                     Grid.Column="1"
                                     ItemsSource="{Binding PrintModes}"
                                     SelectedValue="{Binding SelectedPrintMode}"
                                     SelectedValuePath="Value"
                                     Style="{StaticResource SegmentedSelector}"
                                     HorizontalAlignment="Right">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="开始直播"
                                    Command="{Binding ConnectSelectedRoomCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,10,8" />
                            <Button Content="重连弹幕"
                                    Command="{Binding ConnectSelectedRoomCommand}"
                                    Margin="0,0,10,8" />
                        </WrapPanel>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource FastSortMuted}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <Border DockPanel.Dock="Right"
                                    Background="{StaticResource FastSortBackground}"
                                    CornerRadius="12"
                                    Padding="10,6">
                                <TextBlock Text="未连接"
                                           Foreground="{StaticResource FastSortMuted}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE749;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{StaticResource FastSortText}"
                                           FontSize="17"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="打印机"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FastSortText}" />
                            </StackPanel>
                        </DockPanel>

                        <Border Background="{StaticResource FastSortBackground}"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="未连接本地打印机"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FastSortText}" />
                                <TextBlock Text="标签尺寸按房间模板配置读取"
                                           FontSize="12"
                                           Foreground="{StaticResource FastSortMuted}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <WrapPanel>
                            <Button Content="搜索设备" Margin="0,0,8,0" />
                            <Button Content="断开连接" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               LastChildFill="False"
                               Margin="16,0"
                               VerticalAlignment="Center">
                        <WrapPanel DockPanel.Dock="Right"
                                   VerticalAlignment="Center">
                            <CheckBox Content="仅粉丝打印"
                                      IsChecked="{Binding OnlyPrintFans}"
                                      Margin="0,0,12,0" />
                            <CheckBox Content="去重模式"
                                      IsChecked="{Binding UniqueMode}"
                                      Margin="0,0,12,0" />
                            <CheckBox Content="竞拍模式"
                                      IsChecked="{Binding BidModeEnabled}"
                                      Margin="0,0,12,0" />
                            <CheckBox Content="九宫格模式"
                                      IsChecked="{Binding NineGridModeEnabled}"
                                      Margin="0,0,12,0" />
                            <Button Content="&#xE713;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    ToolTip="弹幕设置" />
                            <Button Content="&#xE72C;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    ToolTip="刷新弹幕"
                                    Command="{Binding ConnectSelectedRoomCommand}" />
                            <Button Content="&#xE738;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Foreground="{StaticResource FastSortDanger}"
                                    ToolTip="断开弹幕"
                                    Command="{Binding StopNativeConnectionCommand}" />
                        </WrapPanel>

                        <Border Background="{StaticResource FastSortBackground}"
                                CornerRadius="12"
                                Padding="10,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="弹幕已断开"
                                       Foreground="{StaticResource FastSortMuted}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </DockPanel>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource FastSortBorder}"
                            BorderThickness="0,0,0,1" />

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding Events}"
                              BorderThickness="0"
                              Background="Transparent"
                              Margin="16,16,16,16">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FastSortBackground}"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Time}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   FontSize="12" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Content}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource FastSortText}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Platform}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
