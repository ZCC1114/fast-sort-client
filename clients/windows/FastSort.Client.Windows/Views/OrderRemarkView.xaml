<UserControl x:Class="FastSort.Client.Windows.Views.OrderRemarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="批次选择"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <TextBlock Text="平台"
                               FontSize="12"
                               Foreground="{StaticResource FastSortMuted}"
                               Margin="0,14,0,6" />
                    <ListBox SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}">
                        <ListBoxItem Content="抖音" Tag="0" />
                        <ListBoxItem Content="小红书" Tag="2" />
                    </ListBox>
                    <TextBlock Text="批次"
                               FontSize="12"
                               Foreground="{StaticResource FastSortMuted}"
                               Margin="0,12,0,6" />
                    <ListBox SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}">
                        <ListBoxItem Content="当前" Tag="current" />
                        <ListBoxItem Content="历史" Tag="history" />
                    </ListBox>
                    <Button Content="刷新批次"
                            Command="{Binding RefreshCommand}"
                            Margin="0,12,0,12" />
                </StackPanel>

                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Time}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="备注字段"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <WrapPanel Margin="0,12,0,0">
                        <CheckBox Content="昵称" IsChecked="True" Margin="0,0,14,0" />
                        <CheckBox Content="编号" IsChecked="True" Margin="0,0,14,0" />
                        <CheckBox Content="序号" Margin="0,0,14,0" />
                        <CheckBox Content="数量" IsChecked="True" Margin="0,0,14,0" />
                        <CheckBox Content="金额" IsChecked="True" Margin="0,0,14,0" />
                    </WrapPanel>
                    <TextBox Text="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="Collapsed" />
                </StackPanel>

                <Border Grid.Row="2"
                        Background="{StaticResource FastSortBackground}"
                        CornerRadius="10"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="标签明细预览"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Grid.Column="1" Text="昵称" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Grid.Column="2" Text="备注内容" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Grid.Column="3" Text="买家标识" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                                <TextBlock Grid.Column="4" Text="时间" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                            </Grid>

                            <ListBox Grid.Row="1"
                                     ItemsSource="{Binding DetailRows}"
                                     SelectedItem="{Binding SelectedRow}"
                                     ItemContainerStyle="{StaticResource PlainListBoxItem}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource FastSortBorder}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,9">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="58" />
                                                    <ColumnDefinition Width="180" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="130" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Id}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="{Binding Meta}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4" Text="{Binding Time}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="3" Margin="0,14,0,0">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource FastSortMuted}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="生成备注映射"
                                Command="{Binding PrimaryActionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0" />
                        <Button Content="执行批次"
                                Command="{Binding PrimaryActionCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="打开商家后台"
                                Command="{Binding SecondaryActionCommand}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
