<UserControl x:Class="FastSort.Client.Windows.Views.OrderRemarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="批次选择"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <ComboBox SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Height="34"
                              Margin="0,12,0,8">
                        <ComboBoxItem Content="抖音" Tag="0" />
                        <ComboBoxItem Content="小红书" Tag="2" />
                    </ComboBox>
                    <ComboBox SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Height="34"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="当前批次" Tag="current" />
                        <ComboBoxItem Content="历史批次" Tag="history" />
                    </ComboBox>
                    <Button Content="刷新批次"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,0,12" />
                </StackPanel>
                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Time}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="备注字段"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <WrapPanel Margin="0,12,0,0">
                        <CheckBox Content="昵称" IsChecked="True" Margin="0,0,16,0" />
                        <CheckBox Content="编号" IsChecked="True" Margin="0,0,16,0" />
                        <CheckBox Content="序号" Margin="0,0,16,0" />
                        <CheckBox Content="数量" IsChecked="True" Margin="0,0,16,0" />
                        <CheckBox Content="金额" IsChecked="True" Margin="0,0,16,0" />
                    </WrapPanel>
                    <TextBox Text="{Binding InputTwo, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,8,0,0"
                             VerticalContentAlignment="Center" />
                </StackPanel>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DetailRows}"
                          SelectedItem="{Binding SelectedRow}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="昵称" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="备注内容" Binding="{Binding Detail}" Width="*" />
                        <DataGridTextColumn Header="买家标识" Binding="{Binding Meta}" Width="180" />
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount}" Width="90" />
                        <DataGridTextColumn Header="时间" Binding="{Binding Time}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource FastSortMuted}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="生成备注映射"
                                Command="{Binding PrimaryActionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0" />
                        <Button Content="打开商家后台"
                                Command="{Binding SecondaryActionCommand}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
