<UserControl x:Class="FastSort.Client.Windows.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <ItemsControl ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    MinWidth="140"
                                    Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="刷新"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="打印测试"
                            Command="{Binding PrimaryActionCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="房间打印配置"
                            Command="{Binding SecondaryActionCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding DetailRows}"
                  SelectedItem="{Binding SelectedRow}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  Background="{StaticResource FastSortSurface}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="模块" Binding="{Binding Kind}" Width="150" />
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="220" />
                <DataGridTextColumn Header="详情" Binding="{Binding Detail}" Width="*" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="150" />
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="220" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
