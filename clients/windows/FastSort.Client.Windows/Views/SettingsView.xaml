<UserControl x:Class="FastSort.Client.Windows.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}">
            <DockPanel>
                <ItemsControl ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    MinWidth="140"
                                    Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Value}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="刷新"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0" />
                    <Button Content="打印测试"
                            Command="{Binding PrimaryActionCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" />
                    <Button Content="房间打印配置"
                            Command="{Binding SecondaryActionCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="配置项"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="{StaticResource FastSortMuted}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </DockPanel>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding DetailRows}"
                         SelectedItem="{Binding SelectedRow}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Kind}"
                                               Foreground="{StaticResource FastSortAccent}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Detail}"
                                               Foreground="{StaticResource FastSortMuted}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Status}"
                                               Foreground="{StaticResource FastSortMuted}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
