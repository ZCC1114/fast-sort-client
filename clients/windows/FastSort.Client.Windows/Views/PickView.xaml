<UserControl x:Class="FastSort.Client.Windows.Views.PickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="批次"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <ComboBox DockPanel.Dock="Right"
                                  Width="110"
                                  SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="当前批次" Tag="current" />
                            <ComboBoxItem Content="历史批次" Tag="history" />
                        </ComboBox>
                    </DockPanel>
                    <Button Content="刷新批次"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,0,12" />
                </StackPanel>
                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}" />
                                    <TextBlock Text="{Binding Time}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="320"
                                  SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag"
                                  Margin="0,0,12,0">
                            <ComboBoxItem Content="抖音" Tag="0" />
                            <ComboBoxItem Content="淘宝" Tag="1" />
                            <ComboBoxItem Content="小红书" Tag="2" />
                            <ComboBoxItem Content="微信" Tag="3" />
                            <ComboBoxItem Content="快手" Tag="4" />
                        </ComboBox>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="260"
                                 Height="34"
                                 VerticalContentAlignment="Center" />
                        <Button Content="搜索"
                                Command="{Binding PrimaryActionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="加载标签/加入黑名单"
                                Command="{Binding PrimaryActionCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0" />
                        <Button Content="重置编号"
                                Command="{Binding SecondaryActionCommand}" />
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding DetailRows}"
                          SelectedItem="{Binding SelectedRow}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="昵称" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="编号/序号" Binding="{Binding Detail}" Width="220" />
                        <DataGridTextColumn Header="数量" Binding="{Binding Meta}" Width="110" />
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount}" Width="100" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="创建时间" Binding="{Binding Time}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Text="{Binding PageText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <CheckBox Content="重置序号" IsChecked="True" VerticalAlignment="Center" Margin="0,0,14,0" />
                        <Button Content="上一页" Command="{Binding PreviousPageCommand}" Margin="0,0,8,0" />
                        <Button Content="下一页" Command="{Binding NextPageCommand}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
