<UserControl x:Class="FastSort.Client.Windows.Views.PickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="{Binding PickBatchPanelTitle}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortText}" />
                    <ListBox SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             SelectionChanged="AutoRefreshSelector_SelectionChanged"
                             Margin="0,12,0,8">
                        <ListBoxItem Content="当前" Tag="current" />
                        <ListBoxItem Content="历史" Tag="history" />
                    </ListBox>
                    <ListBox SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelectorCompact}"
                             SelectionChanged="AutoRefreshSelector_SelectionChanged"
                             Margin="0,0,0,12">
                        <ListBoxItem Content="抖音" Tag="0" />
                        <ListBoxItem Content="淘宝" Tag="1" />
                        <ListBoxItem Content="小红书" Tag="2" />
                        <ListBoxItem Content="微信" Tag="3" />
                        <ListBoxItem Content="快手" Tag="4" />
                    </ListBox>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="44" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="序号"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="1"
                                   Text="批次信息"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortMuted}" />
                    </Grid>
                </StackPanel>

                <Grid DockPanel.Dock="Bottom" Style="{StaticResource PaginationGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding PickBatchPageText}"
                               Style="{StaticResource PaginationInfoText}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="上一页"
                                Command="{Binding PreviousPickBatchPageCommand}"
                                Style="{StaticResource PaginationButton}" />
                        <Button Content="下一页"
                                Command="{Binding NextPickBatchPageCommand}"
                                Style="{StaticResource PaginationButton}"
                                Margin="0" />
                    </StackPanel>
                </Grid>

                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Sequence}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortMuted}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FastSortText}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Time}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource FastSortMuted}"
                                                   Margin="0,5,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="1" Text="昵称" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="2" Text="编号/序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="3" Text="数量" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="4" Text="金额" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="5" Text="创建时间" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="6" Text="操作" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" HorizontalAlignment="Right" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DetailRows}"
                             SelectedItem="{Binding SelectedRow}"
                             ItemContainerStyle="{StaticResource PlainListBoxItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource FastSortBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Sequence}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding Meta}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="5" Text="{Binding Time}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="6"
                                                Content="加入黑名单"
                                                Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                HorizontalAlignment="Right"
                                                Padding="10,5" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Grid Grid.Row="1" Style="{StaticResource PaginationGrid}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageText}" Style="{StaticResource PaginationInfoText}" />
                        <CheckBox Content="重置序号" IsChecked="True" VerticalAlignment="Center" Margin="18,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="上一页" Command="{Binding PreviousPageCommand}" Style="{StaticResource PaginationButton}" />
                        <Button Content="下一页" Command="{Binding NextPageCommand}" Style="{StaticResource PaginationButton}" />
                        <Button Content="重置编号" Command="{Binding SecondaryActionCommand}" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
