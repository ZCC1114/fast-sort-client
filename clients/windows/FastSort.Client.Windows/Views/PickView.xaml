<UserControl x:Class="FastSort.Client.Windows.Views.PickView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="当前批次"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}" />
                        <ListBox DockPanel.Dock="Right"
                                 SelectedValue="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 SelectedValuePath="Tag"
                                 Style="{StaticResource SegmentedSelector}"
                                 Margin="8,0,0,0">
                            <ListBoxItem Content="当前" Tag="current" />
                            <ListBoxItem Content="历史" Tag="history" />
                        </ListBox>
                    </DockPanel>
                    <TextBlock Text="序号    批次信息"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FastSortMuted}"
                               Margin="0,0,0,8" />
                    <Button Content="刷新批次"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,0,12" />
                </StackPanel>

                <ListBox ItemsSource="{Binding PrimaryRows}"
                         SelectedItem="{Binding SelectedRow}"
                         ItemContainerStyle="{StaticResource PlainListBoxItem}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FastSortBackground}"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FastSortText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Time}"
                                               FontSize="12"
                                               Foreground="{StaticResource FastSortMuted}"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ListBox SelectedValue="{Binding InputOne, UpdateSourceTrigger=PropertyChanged}"
                             SelectedValuePath="Tag"
                             Style="{StaticResource SegmentedSelector}"
                             Margin="0,0,12,0">
                        <ListBoxItem Content="抖音" Tag="0" />
                        <ListBoxItem Content="淘宝" Tag="1" />
                        <ListBoxItem Content="小红书" Tag="2" />
                        <ListBoxItem Content="微信" Tag="3" />
                        <ListBoxItem Content="快手" Tag="4" />
                    </ListBox>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="2"
                            Content="搜索"
                            Command="{Binding PrimaryActionCommand}"
                            Style="{StaticResource PrimaryButton}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="1" Text="昵称" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="2" Text="编号/序号" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="3" Text="数量" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="4" Text="金额" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="5" Text="创建时间" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" />
                        <TextBlock Grid.Column="6" Text="操作" FontWeight="SemiBold" Foreground="{StaticResource FastSortMuted}" HorizontalAlignment="Right" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DetailRows}"
                             SelectedItem="{Binding SelectedRow}"
                             ItemContainerStyle="{StaticResource PlainListBoxItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource FastSortBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Id}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource FastSortText}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding Detail}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding Meta}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="4" Text="{Binding Amount}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="5" Text="{Binding Time}" Foreground="{StaticResource FastSortMuted}" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="6"
                                                Content="加入黑名单"
                                                Command="{Binding DataContext.PrimaryActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                HorizontalAlignment="Right"
                                                Padding="10,5" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <DockPanel Grid.Row="3" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageText}" Foreground="{StaticResource FastSortMuted}" VerticalAlignment="Center" />
                        <CheckBox Content="重置序号" IsChecked="True" VerticalAlignment="Center" Margin="18,0,0,0" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="上一页" Command="{Binding PreviousPageCommand}" Margin="0,0,8,0" />
                        <Button Content="下一页" Command="{Binding NextPageCommand}" Margin="0,0,8,0" />
                        <Button Content="重置编号" Command="{Binding SecondaryActionCommand}" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
