<UserControl x:Class="FastSort.Client.Windows.Views.DanmakuCookieTestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinHeight="560">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource FastSortSurface}"
                BorderBrush="{StaticResource FastSortBorder}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox ItemsSource="{Binding Platforms}"
                          SelectedItem="{Binding SelectedPlatform}"
                          DisplayMemberPath="Name"
                          Height="34"
                          VerticalAlignment="Center" />
                <TextBox Grid.Column="1"
                         Text="{Binding LoginUrlText, Mode=OneWay}"
                         IsReadOnly="True"
                         Height="34"
                         Margin="10,0"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="2"
                        Content="Open"
                        Command="{Binding OpenSelectedPlatformCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="72"
                        Margin="0,0,8,0" />
                <Button Grid.Column="3"
                        Content="Collect"
                        Click="CollectButton_Click"
                        MinWidth="72"
                        Margin="0,0,8,0" />
                <Button Grid.Column="4"
                        Content="Save Entry"
                        Command="{Binding SaveCookieCommand}"
                        MinWidth="88"
                        Margin="0,0,8,0" />
                <Button Grid.Column="5"
                        Content="Connect"
                        Command="{Binding RunNativePreflightCommand}"
                        MinWidth="72"
                        Margin="0,0,8,0" />
                <Button Grid.Column="6"
                        Content="Stop"
                        Command="{Binding StopNativeConnectionCommand}"
                        MinWidth="72" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource FastSortSurface}"
                    BorderBrush="{StaticResource FastSortBorder}"
                    BorderThickness="1"
                    CornerRadius="8">
                <wv2:WebView2 x:Name="AuthWebView"
                              NavigationStarting="AuthWebView_NavigationStarting"
                              NavigationCompleted="AuthWebView_NavigationCompleted" />
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource FastSortSurface}"
                            BorderBrush="{StaticResource FastSortBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Current URL"
                                       Foreground="{StaticResource FastSortMuted}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding CurrentUrl}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource FastSortText}"
                                       Margin="0,4,0,12" />
                            <TextBlock Text="{Binding HitStatusText}"
                                       Foreground="{StaticResource FastSortAccent}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding CollectionResultText}"
                                       Foreground="{StaticResource FastSortMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                            <TextBlock Text="{Binding SaveResultText}"
                                       Foreground="{StaticResource FastSortMuted}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource FastSortSurface}"
                            BorderBrush="{StaticResource FastSortBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Masked Cookie"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}"
                                       Margin="0,0,0,8" />
                            <TextBox Text="{Binding MaskedCookieHeader, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="110"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource FastSortSurface}"
                            BorderBrush="{StaticResource FastSortBorder}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Native Adapter Events"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}"
                                       Margin="0,0,0,8" />
                            <ListView ItemsSource="{Binding Events}"
                                      MinHeight="150">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="64" />
                                        <GridViewColumn Header="Platform" DisplayMemberBinding="{Binding Platform}" Width="90" />
                                        <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="86" />
                                        <GridViewColumn Header="Content" DisplayMemberBinding="{Binding Content}" Width="230" />
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
