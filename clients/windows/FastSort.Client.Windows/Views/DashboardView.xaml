<UserControl x:Class="FastSort.Client.Windows.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="680">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ItemsControl Grid.Row="0" ItemsSource="{Binding Stats}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="5" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,12,12" MinHeight="86">
                        <DockPanel LastChildFill="True">
                            <Border Width="46"
                                    Height="42"
                                    DockPanel.Dock="Left"
                                    Background="{StaticResource FastSortAccentSoft}"
                                    CornerRadius="23"
                                    Margin="0,0,10,0">
                                <TextBlock Text="{Binding IconText}"
                                           Foreground="{StaticResource FastSortAccent}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Value}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource FastSortText}" />
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12"
                                           Foreground="{StaticResource FastSortMuted}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,14">
                            <TextBlock Text="打印报表"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,8" />
                            <Button Content="7 天" Style="{StaticResource TopbarTextButton}" Margin="0,0,8,8" />
                            <Button Content="30 天" Style="{StaticResource TopbarTextButton}" Margin="0,0,8,8" />
                            <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="0,0,0,8" />
                        </WrapPanel>
                        <Border Height="310"
                                Background="{StaticResource FastSortBackground}"
                                CornerRadius="10"
                                BorderBrush="{StaticResource FastSortBorder}"
                                BorderThickness="1">
                            <Grid Margin="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Viewbox Grid.Row="0" Stretch="Fill">
                                    <Canvas Width="760" Height="230">
                                        <ItemsControl ItemsSource="{Binding ChartHorizontalLines}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Line X1="48"
                                                          X2="732"
                                                          Y1="{Binding Y}"
                                                          Y2="{Binding Y}"
                                                          Stroke="{StaticResource FastSortBorder}"
                                                          StrokeThickness="1" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Line X1="48"
                                              X2="732"
                                              Y1="186"
                                              Y2="186"
                                              Stroke="{StaticResource FastSortMuted}"
                                              StrokeThickness="1" />
                                        <Line X1="48"
                                              X2="48"
                                              Y1="18"
                                              Y2="186"
                                              Stroke="{StaticResource FastSortMuted}"
                                              StrokeThickness="1" />

                                        <Polyline Points="{Binding ChartPolylinePoints}"
                                                  Stroke="{StaticResource FastSortAccent}"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />

                                        <ItemsControl ItemsSource="{Binding ChartYTicks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{StaticResource FastSortMuted}"
                                                               FontSize="11"
                                                               Width="38"
                                                               TextAlignment="Right" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <ItemsControl ItemsSource="{Binding ChartXTicks}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Label}"
                                                               Foreground="{StaticResource FastSortMuted}"
                                                               FontSize="11"
                                                               Width="56"
                                                               TextAlignment="Center" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding TrendSummary}"
                                           Foreground="{StaticResource FastSortMuted}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           Margin="0,14,0,0" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="最新理货批次"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}"
                                   Margin="0,0,0,14" />
                        <ItemsControl ItemsSource="{Binding Batches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource FastSortBackground}"
                                            CornerRadius="10"
                                            Padding="12"
                                            Margin="0,0,0,10">
                                        <DockPanel>
                                            <TextBlock Text="{Binding Status}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{StaticResource FastSortAccent}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                            <StackPanel>
                                                <TextBlock Text="{Binding Platform}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FastSortText}" />
                                                <TextBlock Text="{Binding BatchName}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource FastSortMuted}"
                                                           Margin="0,5,0,0" />
                                                <TextBlock Text="{Binding CreatedTime}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource FastSortMuted}"
                                                           Margin="0,5,0,0" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="直播间"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FastSortText}"
                                   Margin="0,0,0,14" />
                        <ItemsControl ItemsSource="{Binding Rooms}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource FastSortBackground}"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="36"
                                                    Height="36"
                                                    CornerRadius="9"
                                                    Background="{Binding BadgeBackground}"
                                                    VerticalAlignment="Center"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding AvatarUrl}"
                                                           Stretch="UniformToFill">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding AvatarText}"
                                                               Foreground="{Binding BadgeForeground}"
                                                               FontSize="15"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AvatarUrl}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FastSortText}"
                                                           TextWrapping="Wrap" />
                                                <WrapPanel Margin="0,4,0,0">
                                                    <Border Background="{Binding BadgeBackground}"
                                                            CornerRadius="9"
                                                            Padding="7,2"
                                                            Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Platform}"
                                                                   Foreground="{Binding BadgeForeground}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Handle}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource FastSortMuted}" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="黑名单"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FastSortText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BlacklistTotal, StringFormat=共 {0} 条}"
                                       Foreground="{StaticResource FastSortMuted}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Blacklist}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="{Binding Level}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{StaticResource FastSortAccent}"
                                                   FontWeight="SemiBold" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}" />
                                            <TextBlock Text="{Binding Meta}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding ErrorText}"
                                   Foreground="{StaticResource FastSortDanger}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
