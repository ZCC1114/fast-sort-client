<Window x:Class="FastSort.Client.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FastSort.Client.Windows.Views"
        Title="迅拣"
        Width="1000"
        Height="760"
        MinWidth="960"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource FastSortBackground}">
    <Grid>
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="42,24,0,0">
                <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource FastSortAccent}">
                    <TextBlock Text="拣" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Text="迅拣" Foreground="{StaticResource FastSortText}" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="弹幕标签打印" Foreground="{StaticResource FastSortMuted}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Width="420" Padding="30" Style="{StaticResource CardBorder}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel DataContext="{Binding Login}">
                    <TextBlock Text="Welcome to 迅拣" Foreground="{StaticResource FastSortMuted}" FontSize="13" FontWeight="Medium" />
                    <TextBlock Text="Login" Foreground="{StaticResource FastSortText}" FontSize="34" FontWeight="Bold" Margin="0,6,0,18" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton Content="SMS" IsChecked="{Binding IsSmsLogin}" GroupName="LoginMode" Margin="0,0,18,0" />
                        <RadioButton Content="Account" IsChecked="{Binding IsAccountLogin}" GroupName="LoginMode" />
                    </StackPanel>

                    <TextBlock Text="手机号" Foreground="{StaticResource FastSortMuted}" FontSize="12" />
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Height="34" Margin="0,6,0,14" />

                    <Grid>
                        <StackPanel Visibility="{Binding IsSmsLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="验证码" Foreground="{StaticResource FastSortMuted}" FontSize="12" VerticalAlignment="Center" />
                                <Button Content="{Binding SendCodeText}" Command="{Binding SendCodeCommand}" DockPanel.Dock="Right" Foreground="{StaticResource FastSortAccent}" Background="Transparent" BorderThickness="0" />
                            </DockPanel>
                            <UniformGrid Columns="4" Margin="0,0,0,14">
                                <TextBox Text="{Binding Code1, UpdateSourceTrigger=PropertyChanged}" Height="44" MaxLength="1" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code2, UpdateSourceTrigger=PropertyChanged}" Height="44" MaxLength="1" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code3, UpdateSourceTrigger=PropertyChanged}" Height="44" MaxLength="1" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code4, UpdateSourceTrigger=PropertyChanged}" Height="44" MaxLength="1" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsAccountLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="密码" Foreground="{StaticResource FastSortMuted}" FontSize="12" />
                            <PasswordBox Height="34" Margin="0,6,0,14" PasswordChanged="PasswordBox_PasswordChanged" />
                        </StackPanel>
                    </Grid>

                    <CheckBox IsChecked="{Binding TermsAccepted}" Margin="0,0,0,16">
                        <TextBlock FontSize="12" Foreground="{StaticResource FastSortMuted}" Text="我已阅读并同意服务协议与隐私政策" />
                    </CheckBox>

                    <Button Content="Login" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButton}" Height="40" />
                    <TextBlock Text="{Binding ErrorText}" Foreground="{StaticResource FastSortDanger}" FontSize="13" TextWrapping="Wrap" Margin="0,12,0,0" />
                    <TextBlock Text="{Binding SuccessText}" Foreground="{StaticResource FastSortSuccess}" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ICP备案号：苏ICP备2025175795号-1A" Foreground="{StaticResource FastSortMuted}" FontSize="12" TextAlignment="Center" />
                <TextBlock Text="Copyright © 2026 无锡市道亨科技有限责任公司" Foreground="{StaticResource FastSortMuted}" FontSize="12" TextAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>
        </Grid>

        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="224" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource FastSortSidebar}" BorderBrush="{StaticResource FastSortBorder}" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True" Margin="10,18,10,16">
                    <StackPanel DockPanel.Dock="Top" Margin="4,0,4,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource FastSortAccent}">
                                <TextBlock Text="拣" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="迅拣" Foreground="{StaticResource FastSortText}" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="弹幕标签打印" Foreground="{StaticResource FastSortMuted}" FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Command="{Binding SelectRouteCommand}" CommandParameter="{Binding ProfileRoute}" Style="{StaticResource SidebarRouteButton}" Margin="0,0,0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ProfileRoute.IconText}" Width="22" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource FastSortMuted}" FontSize="15" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding ProfileRoute.Title}" Foreground="{StaticResource FastSortText}" FontSize="13" FontWeight="Medium" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Command="{Binding LogoutCommand}" Style="{StaticResource SidebarRouteButton}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE8BB;" Width="22" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{StaticResource FastSortMuted}" FontSize="15" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="退出登录" Foreground="{StaticResource FastSortMuted}" FontSize="13" FontWeight="Medium" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Routes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectRouteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,0,4">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarRouteButton}">
                                            <Setter Property="Foreground" Value="{StaticResource FastSortText}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource FastSortAccentSoft}" />
                                                    <Setter Property="Foreground" Value="{StaticResource FastSortAccent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding IconText}" Width="22" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="15" FontFamily="Segoe MDL2 Assets" TextAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="13" FontWeight="Medium" Margin="10,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource FastSortSurface}" BorderBrush="{StaticResource FastSortBorder}" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True" Margin="24,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Manual" Command="{Binding OpenManualCommand}" Style="{StaticResource TopbarTextButton}" Margin="0,0,12,0" />
                            <Button Content="Upgrade VIP" Command="{Binding SelectRouteCommand}" CommandParameter="{Binding PaymentRoute}" Style="{StaticResource VipButton}" Margin="0,0,12,0" />
                            <TextBlock Text="{Binding ProfileName}" VerticalAlignment="Center" Foreground="{StaticResource FastSortText}" FontSize="13" FontWeight="Medium" Margin="0,0,12,0" />
                            <TextBlock Text="{Binding VipStatusText}" VerticalAlignment="Center" Foreground="{StaticResource FastSortMuted}" FontSize="13" FontWeight="Medium" />
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedRouteTitle}" Foreground="{StaticResource FastSortText}" FontSize="21" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedRouteSubtitle}" Foreground="{StaticResource FastSortMuted}" FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Background="{StaticResource FastSortGroupedBackground}">
                    <Border Padding="24">
                        <Grid>
                            <views:DashboardView DataContext="{Binding Dashboard}"
                                                 Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Dashboard}" />
                            <views:LiveRoomsView DataContext="{Binding LiveRooms}"
                                                 Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=LiveRooms}" />
                            <views:EntertainmentView DataContext="{Binding BusinessPage}"
                                                     Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Entertainment}" />
                            <views:PickView DataContext="{Binding BusinessPage}"
                                            Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Pick}" />
                            <views:OrderRemarkView DataContext="{Binding BusinessPage}"
                                                   Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=DouyinRemark}" />
                            <views:BlacklistView DataContext="{Binding BusinessPage}"
                                                 Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Blacklist}" />
                            <views:VipOrdersView DataContext="{Binding BusinessPage}"
                                                 Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=VipOrder}" />
                            <views:DanmakuCookieTestView DataContext="{Binding DanmakuCookieTest}"
                                                         Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=DanmakuCookieTest}" />
                            <views:SettingsView DataContext="{Binding BusinessPage}"
                                                Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Settings}" />
                            <views:ProfileView DataContext="{Binding BusinessPage}"
                                               Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Profile}" />
                            <views:PaymentView DataContext="{Binding BusinessPage}"
                                               Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Payment}" />
                            <views:PrinterTestView DataContext="{Binding BusinessPage}"
                                                   Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=PrinterTest}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
