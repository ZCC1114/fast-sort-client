<Window x:Class="FastSort.Client.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FastSort.Client.Windows.Views"
        Title="迅拣"
        Width="1180"
        Height="760"
        MinWidth="1180"
        MinHeight="760"
        Background="{StaticResource FastSortBackground}">
    <Grid>
        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="迅拣"
                       Foreground="{StaticResource FastSortAccent}"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="42,24,0,0" />

            <Border Grid.Row="1"
                    Width="420"
                    Padding="30"
                    Background="{StaticResource FastSortSurface}"
                    CornerRadius="18"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel DataContext="{Binding Login}">
                    <TextBlock Text="Welcome to 迅拣"
                               Foreground="{StaticResource FastSortMuted}"
                               FontSize="13"
                               FontWeight="Medium" />
                    <TextBlock Text="Login"
                               Foreground="{StaticResource FastSortText}"
                               FontSize="34"
                               FontWeight="Bold"
                               Margin="0,6,0,18" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton Content="SMS"
                                     IsChecked="{Binding IsSmsLogin}"
                                     GroupName="LoginMode"
                                     Margin="0,0,18,0" />
                        <RadioButton Content="Account"
                                     IsChecked="{Binding IsAccountLogin}"
                                     GroupName="LoginMode" />
                    </StackPanel>

                    <TextBlock Text="phone number"
                               Foreground="{StaticResource FastSortMuted}"
                               FontSize="12" />
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Height="34"
                             Margin="0,6,0,14" />

                    <Grid>
                        <StackPanel Visibility="{Binding IsSmsLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="verification code"
                                           Foreground="{StaticResource FastSortMuted}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <Button Content="{Binding SendCodeText}"
                                        Command="{Binding SendCodeCommand}"
                                        DockPanel.Dock="Right"
                                        Foreground="{StaticResource FastSortAccent}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand" />
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBox Text="{Binding Code1, UpdateSourceTrigger=PropertyChanged}"
                                         Width="48"
                                         Height="44"
                                         MaxLength="1"
                                         FontSize="20"
                                         FontWeight="SemiBold"
                                         TextAlignment="Center"
                                         Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code2, UpdateSourceTrigger=PropertyChanged}"
                                         Width="48"
                                         Height="44"
                                         MaxLength="1"
                                         FontSize="20"
                                         FontWeight="SemiBold"
                                         TextAlignment="Center"
                                         Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code3, UpdateSourceTrigger=PropertyChanged}"
                                         Width="48"
                                         Height="44"
                                         MaxLength="1"
                                         FontSize="20"
                                         FontWeight="SemiBold"
                                         TextAlignment="Center"
                                         Margin="0,0,10,0" />
                                <TextBox Text="{Binding Code4, UpdateSourceTrigger=PropertyChanged}"
                                         Width="48"
                                         Height="44"
                                         MaxLength="1"
                                         FontSize="20"
                                         FontWeight="SemiBold"
                                         TextAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAccountLogin, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="password"
                                       Foreground="{StaticResource FastSortMuted}"
                                       FontSize="12" />
                            <PasswordBox Height="34"
                                         Margin="0,6,0,14"
                                         PasswordChanged="PasswordBox_PasswordChanged" />
                        </StackPanel>
                    </Grid>

                    <CheckBox IsChecked="{Binding TermsAccepted}"
                              Margin="0,0,0,16">
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource FastSortMuted}">
                            <Run Text="I agree Terms of Service and Privacy Policy." />
                        </TextBlock>
                    </CheckBox>

                    <Button Content="Login"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Height="40" />

                    <TextBlock Text="{Binding ErrorText}"
                               Foreground="#FFE74C3C"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,12,0,0" />
                    <TextBlock Text="{Binding SuccessText}"
                               Foreground="#FF27AE60"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="ICP备案号：苏ICP备2025175795号-1A"
                           Foreground="{StaticResource FastSortMuted}"
                           FontSize="12"
                           TextAlignment="Center" />
                <TextBlock Text="Copyright © 2026 无锡市道亨科技有限责任公司"
                           Foreground="{StaticResource FastSortMuted}"
                           FontSize="12"
                           TextAlignment="Center"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Grid>

        <Grid Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="98" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource FastSortSurface}"
                    BorderBrush="{StaticResource FastSortBorder}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True" Margin="10,18,10,16">
                    <Border DockPanel.Dock="Top"
                            Width="48"
                            Height="48"
                            CornerRadius="16"
                            Background="{StaticResource FastSortAccentSoft}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,18">
                        <TextBlock Text="拣"
                                   Foreground="{StaticResource FastSortAccent}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Center">
                        <Button Content="U"
                                Command="{Binding SelectRouteCommand}"
                                CommandParameter="{Binding ProfileRoute}"
                                Width="38"
                                Height="38"
                                Margin="0,0,0,12" />
                        <Button Content="退出"
                                Command="{Binding LogoutCommand}"
                                Width="56" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Routes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Title}"
                                        Command="{Binding DataContext.SelectRouteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,0,8"
                                        MinHeight="40" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="24,0">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Manual"
                                Command="{Binding OpenManualCommand}"
                                Margin="0,0,12,0" />
                        <Button Content="Upgrade VIP"
                                Command="{Binding SelectRouteCommand}"
                                CommandParameter="{Binding PaymentRoute}"
                                Margin="0,0,12,0"
                                Style="{StaticResource PrimaryButton}" />
                        <TextBlock Text="{Binding ProfileName}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FastSortText}"
                                   Margin="0,0,12,0" />
                        <TextBlock Text="{Binding VipStatusText}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FastSortMuted}" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1" Margin="24,0,24,24">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedRouteTitle}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FastSortText}"
                                   Margin="0,0,0,18" />
                        <StackPanel DataContext="{Binding Dashboard}"
                                    Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=Dashboard}">
                            <ItemsControl ItemsSource="{Binding Stats}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="5" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource FastSortSurface}"
                                                CornerRadius="18"
                                                Padding="16"
                                                Margin="0,0,12,18">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Value}"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource FastSortText}" />
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource FastSortMuted}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="390" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                    <Border Background="{StaticResource FastSortSurface}"
                                            CornerRadius="18"
                                            Padding="20"
                                            Margin="0,0,0,18">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="打印报表"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FastSortText}" />
                                                <Button Content="刷新"
                                                        Command="{Binding RefreshCommand}"
                                                        DockPanel.Dock="Right" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding TrendSummary}"
                                                       Foreground="{StaticResource FastSortMuted}"
                                                       FontSize="14"
                                                       Margin="0,18,0,0" />
                                            <Border Height="190"
                                                    Background="{StaticResource FastSortBackground}"
                                                    CornerRadius="12"
                                                    Margin="0,14,0,0">
                                                <TextBlock Text="趋势图组件将在图表基础组件阶段补齐"
                                                           Foreground="{StaticResource FastSortMuted}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource FastSortSurface}"
                                            CornerRadius="18"
                                            Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="最新理货批次"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}"
                                                       Margin="0,0,0,14" />
                                            <ItemsControl ItemsSource="{Binding Batches}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource FastSortBackground}"
                                                                CornerRadius="10"
                                                                Padding="12"
                                                                Margin="0,0,0,10">
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding Status}"
                                                                           Foreground="{StaticResource FastSortAccent}"
                                                                           DockPanel.Dock="Right" />
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Platform}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource FastSortText}" />
                                                                    <TextBlock Text="{Binding BatchName}"
                                                                               Foreground="{StaticResource FastSortMuted}"
                                                                               Margin="0,4,0,0" />
                                                                    <TextBlock Text="{Binding CreatedTime}"
                                                                               Foreground="{StaticResource FastSortMuted}"
                                                                               FontSize="12"
                                                                               Margin="0,4,0,0" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <Border Background="{StaticResource FastSortSurface}"
                                            CornerRadius="18"
                                            Padding="20"
                                            Margin="0,0,0,18">
                                        <StackPanel>
                                            <TextBlock Text="直播间"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FastSortText}"
                                                       Margin="0,0,0,14" />
                                            <ItemsControl ItemsSource="{Binding Rooms}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,0,0,12">
                                                            <TextBlock Text="{Binding Platform}"
                                                                       Foreground="{StaticResource FastSortAccent}"
                                                                       DockPanel.Dock="Right" />
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource FastSortText}" />
                                                                <TextBlock Text="{Binding Handle}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource FastSortMuted}" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource FastSortSurface}"
                                            CornerRadius="18"
                                            Padding="20">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,14">
                                                <TextBlock Text="黑名单"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FastSortText}" />
                                                <TextBlock Text="{Binding BlacklistTotal, StringFormat=共 {0} 条}"
                                                           DockPanel.Dock="Right"
                                                           Foreground="{StaticResource FastSortMuted}" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Blacklist}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,0,0,12">
                                                            <TextBlock Text="{Binding Level}"
                                                                       Foreground="{StaticResource FastSortAccent}"
                                                                       DockPanel.Dock="Right" />
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding OrderName}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource FastSortText}" />
                                                                <TextBlock Text="{Binding Meta}"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource FastSortMuted}" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding ErrorText}"
                                       Foreground="#FFE74C3C"
                                       Margin="0,12,0,0" />
                        </StackPanel>

                        <views:LiveRoomsView DataContext="{Binding LiveRooms}"
                                             Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=LiveRooms}" />

                        <views:DanmakuCookieTestView DataContext="{Binding DanmakuCookieTest}"
                                                     Visibility="{Binding DataContext.SelectedRoute, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumEqualsToVisibilityConverter}, ConverterParameter=DanmakuCookieTest}" />

                        <views:BusinessPageView DataContext="{Binding BusinessPage}"
                                                Visibility="{Binding DataContext.IsBusinessPageSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
